> nameEx("build_objectives")
> ### * build_objectives
> 
> flush(stderr()); flush(stdout())
> 
> ### Name: build_objectives
> ### Title: Build Optimization Objectives
> ### Aliases: build_objectives
> 
> ### ** Examples
> 
> ## Not run: 
> ##D design <- build_design(
> ##D   model_name = "ancova_cont_2arms",
> ##D   target_params = "b_arm2"
> ##D )
> ##D 
> ##D # Find minimum sample size for 80% power
> ##D obj <- build_objectives(
> ##D   design = design,
> ##D   search = list(n_total = c(50, 500)),
> ##D   objectives = list(pwr_eff = target(0.80)),
> ##D   constant = list(
> ##D     b_arm_treat = 0.3,
> ##D     thr_dec_eff = 0.975, thr_dec_fut = 0.5,
> ##D     thr_fx_eff = 0.2, thr_fx_fut = 0,
> ##D     p_alloc = list(c(0.5, 0.5)),
> ##D     intercept = 0, b_covariate = 0.3, sigma = 1
> ##D   )
> ##D )
> ##D 
> ##D # Multi-objective: power vs sample size tradeoff
> ##D obj <- build_objectives(
> ##D   design = design,
> ##D   search = list(n_total = c(50, 500), b_arm_treat = c(0.2, 0.6)),
> ##D   objectives = list(pwr_eff = "maximize", n_total = "minimize"),
> ##D   constant = list(...)
> ##D )
> ## End(Not run)
> 
> 
> 
