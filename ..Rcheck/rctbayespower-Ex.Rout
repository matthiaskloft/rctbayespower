> nameEx("build_sim_fn")
> ### * build_sim_fn
> 
> flush(stderr()); flush(stdout())
> 
> ### Name: build_sim_fn
> ### Title: Build Simulation Function Object
> ### Aliases: build_sim_fn
> 
> ### ** Examples
> 
> ## Not run: 
> ##D # Custom simulation function
> ##D my_sim <- function(n_total, effect_size, noise_sd) {
> ##D   arm <- factor(sample(c("ctrl", "treat"), n_total, replace = TRUE))
> ##D   data.frame(
> ##D     outcome = rnorm(n_total, effect_size * (as.integer(arm) - 1), noise_sd),
> ##D     covariate = rnorm(n_total),
> ##D     arm = arm
> ##D   )
> ##D }
> ##D 
> ##D # Wrap with test arguments
> ##D sim_fn <- build_sim_fn(
> ##D   fn = my_sim,
> ##D   test_args = list(n_total = 10, effect_size = 0.5, noise_sd = 1)
> ##D )
> ##D 
> ##D # Use directly
> ##D data <- do.call(sim_fn, list(n_total = 100, effect_size = 0.3, noise_sd = 1))
> ##D 
> ##D # Access schema
> ##D sim_fn@output_schema
> ## End(Not run)
> 
> 
> 
