> 
> # List all predefined models
> show_predefined_models()
[1] "ancova_cont_2arms" "ancova_cont_3arms"
> 
> # Filter to ANCOVA models
> show_predefined_models("ancova")
[1] "ancova_cont_2arms" "ancova_cont_3arms"
